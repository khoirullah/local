<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>{{#str}}invoicequeue, local_corporatecredits{{/str}}</h2>
            <p class="text-muted mb-0">
                {{#str}}manageincominginvoice, local_corporatecredits{{/str}}
            </p>
        </div>
    </div>

    {{^hasrecords}}
        <div class="alert alert-info text-center">
            <i class="fa fa-info-circle me-2"></i>
            {{#str}}noinvoicefound, local_corporatecredits{{/str}}
        </div>
    {{/hasrecords}}

    {{#hasrecords}}
    <div class="card shadow-sm border-0">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">

                    <tr>
                        <th>#</th>
                        <th>{{#str}}company, local_company{{/str}}</th>
                        <th>{{#str}}invoice{{/str}}</th>
                        <th>{{#str}}coins, local_corporatecredits{{/str}}</th>
                        <th>{{#str}}amount{{/str}}</th>
                        <th>{{#str}}paymentmethod, local_corporatecredits{{/str}}</th>
                        <th>{{#str}}status{{/str}}</th>
                        <th class="text-end">
                            {{#str}}actions{{/str}}
                        </th>
                    </tr>

                </thead>

                <tbody>

                {{#items}}

                    <tr>

                        <td>
                            <strong>#{{id}}</strong>
                        </td>

                        <td>

                            <strong>{{companyname}}</strong>

                        </td>

                        <td>

                            <code>{{invoicecode}}</code>

                        </td>

                        <td>

                            <span class="badge bg-primary">

                                {{coins}} Coins

                            </span>

                        </td>

                        <td>

                            <strong>

                                Rp {{amount}}

                            </strong>

                        </td>

                        <td>

                            {{paymentmethod}}

                        </td>

                        <td>

                            {{#statuspending}}
                                <span class="badge bg-warning text-dark">
                                    Pending
                                </span>
                            {{/statuspending}}

                            {{#statusprocessing}}
                                <span class="badge bg-info">
                                    Processing
                                </span>
                            {{/statusprocessing}}

                            {{#statuscompleted}}
                                <span class="badge bg-success">
                                    Completed
                                </span>
                            {{/statuscompleted}}

                            {{#statusfailed}}
                                <span class="badge bg-danger">
                                    Failed
                                </span>
                            {{/statusfailed}}

                        </td>

                        <td class="text-end">

                            {{#statuspending}}

                                <a
                                    href="{{processurl}}"
                                    class="btn btn-success btn-sm"
                                    onclick="return confirm('Approve this invoice?');">

                                    <i class="fa fa-check me-1"></i>

                                    Approve

                                </a>

                            {{/statuspending}}

                            {{^statuspending}}

                                <span class="text-muted">

                                    —

                                </span>

                            {{/statuspending}}

                        </td>

                    </tr>

                {{/items}}

                </tbody>

            </table>

        </div>

    </div>

    {{/hasrecords}}

</div>