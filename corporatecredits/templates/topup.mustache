<div class="alert alert-info">

    <strong>
        {{#str}}coinprice, local_corporatecredits{{/str}}:
    </strong>

    {{currency}} {{coinpriceformatted}}

    <br>

    <strong>
        {{#str}}minimumtopup, local_corporatecredits{{/str}}:
    </strong>

    {{minimumtopup}}
    {{#str}}coins, local_corporatecredits{{/str}}

    <br>

    <strong>
        {{#str}}maximumtopup, local_corporatecredits{{/str}}:
    </strong>

    {{maximumtopup}}
    {{#str}}coins, local_corporatecredits{{/str}}

</div>

<form method="post">

    <input
        type="hidden"
        name="coins"
        id="selected-coins"
        value="10000">
        
    <input
        type="hidden"
        name="sesskey"
        value="{{sesskey}}">

    <div class="wallet-topup-container">

        <div class="wallet-header">

            <div>
                <h1>
                    {{#str}}topupwallet, local_corporatecredits{{/str}}
                </h1>

                <p>
                    {{#str}}topupwallet_desc, local_corporatecredits{{/str}}
                </p>
            </div>

            <div class="balance-card">

                <div class="balance-icon">
                    <i class="fa fa-wallet"></i>
                </div>

                <div>
                    <small>
                        {{#str}}currentbalance, local_corporatecredits{{/str}}
                    </small>

                    <h2>
                        {{balance}}
                        <span>
                            {{#str}}coins, local_corporatecredits{{/str}}
                        </span>
                    </h2>
                </div>

            </div>

        </div>

        <div class="section-card">

            <h3>
                1.
                {{#str}}chooseamount, local_corporatecredits{{/str}}
            </h3>

            <div class="amount-grid">

                <div class="amount-card" data-coins="1000">
                    <div class="coin-icon">🪙</div>
                    <div class="amount">1,000</div>
                    <div class="label">
                        {{#str}}coins, local_corporatecredits{{/str}}
                    </div>
                </div>

                <div class="amount-card" data-coins="5000">
                    <div class="coin-icon">🪙</div>
                    <div class="amount">5,000</div>
                    <div class="label">
                        {{#str}}coins, local_corporatecredits{{/str}}
                    </div>
                </div>

                <div class="amount-card active" data-coins="10000">

                    <div class="checkmark">
                        <i class="fa fa-check"></i>
                    </div>

                    <div class="coin-icon">🪙</div>
                    <div class="amount">10,000</div>
                    <div class="label">
                        {{#str}}coins, local_corporatecredits{{/str}}
                    </div>

                </div>

                <div class="amount-card" data-coins="25000">
                    <div class="coin-icon">🪙</div>
                    <div class="amount">25,000</div>
                    <div class="label">
                        {{#str}}coins, local_corporatecredits{{/str}}
                    </div>
                </div>

                <div class="amount-card" data-coins="50000">
                    <div class="coin-icon">🪙</div>
                    <div class="amount">50,000</div>
                    <div class="label">
                        {{#str}}coins, local_corporatecredits{{/str}}
                    </div>
                </div>

                <div class="amount-card" data-coins="100000">
                    <div class="coin-icon">🪙</div>
                    <div class="amount">100,000</div>
                    <div class="label">
                        {{#str}}coins, local_corporatecredits{{/str}}
                    </div>
                </div>

                <div class="custom-card">

                    <label>
                        {{#str}}customamount, local_corporatecredits{{/str}}
                    </label>

                    <div class="custom-input">
                        <input
                            type="text"
                            id="custom-amount"
                            placeholder="{{#str}}enteramount, local_corporatecredits{{/str}}">
                        <span>
                            {{#str}}coins, local_corporatecredits{{/str}}
                        </span>
                    </div>

                </div>

            </div>

        </div>

        <div class="section-card">

            <div class="summary-header">

                <h3>
                    2.
                    {{#str}}paymentsummary, local_corporatecredits{{/str}}
                </h3>

                <span class="secure-badge">
                    <i class="fa fa-shield-alt"></i>
                    {{#str}}securetransaction, local_corporatecredits{{/str}}
                </span>

            </div>

            <div class="summary-grid">

                <div class="summary-item">

                    <div class="summary-icon">
                        <i class="fa fa-coins"></i>
                    </div>

                    <div>
                        <small>
                            {{#str}}youwillreceive, local_corporatecredits{{/str}}
                        </small>

                        <h2 id="summary-coins">
                            10,000
                            {{#str}}coins, local_corporatecredits{{/str}}
                        </h2>
                    </div>

                </div>

                <div class="divider"></div>

                <div class="summary-item">

                    <div class="summary-icon">
                        <i class="fa fa-file-invoice-dollar"></i>
                    </div>

                    <div>
                        <small>
                            {{#str}}totalpayment, local_corporatecredits{{/str}}
                        </small>

                        <h2 id="summary-payment">
                            {{currency}} 10.000.000
                        </h2>

                </div>

            </div>

        </div>

        <button
            type="submit"
            class="topup-btn">

            {{#str}}topupnow, local_corporatecredits{{/str}}
            <i class="fa fa-arrow-right ml-2"></i>

        </button>

        <div class="payment-note">
            🔒
            {{#str}}paymentsecure, local_corporatecredits{{/str}}\
        </div>

    </div>

</form>

<script>
document.addEventListener('DOMContentLoaded', () => {

    const RATE = {{coinprice}};
    const CURRENCY = '{{currency}}';
    
    const cards =
        document.querySelectorAll('.amount-card');

    const customInput =
        document.getElementById('custom-amount');

    const summaryCoins =
        document.getElementById('summary-coins');

    const summaryPayment =
        document.getElementById('summary-payment');

    const selectedCoinsInput =
        document.getElementById('selected-coins');

    function format(number) {
        return new Intl.NumberFormat('id-ID')
            .format(number);
    }

    function updateSummary(coins) {

        coins = parseInt(coins) || 0;

        selectedCoinsInput.value = coins;

        summaryCoins.textContent =
            format(coins) + ' {{#str}}coins, local_corporatecredits{{/str}}';

        summaryPayment.textContent =
            CURRENCY + ' ' +
            format(coins * RATE);
    }

    cards.forEach(card => {

        card.addEventListener('click', () => {

            cards.forEach(c => {
                c.classList.remove('active');

                const mark =
                    c.querySelector('.checkmark');

                if (mark) {
                    mark.remove();
                }
            });

            card.classList.add('active');

            const checkmark =
                document.createElement('div');

            checkmark.className = 'checkmark';

            checkmark.innerHTML =
                '<i class="fa fa-check"></i>';

            card.appendChild(checkmark);

            customInput.value = '';

            updateSummary(
                card.dataset.coins
            );

        });

    });

    customInput.addEventListener('input', function() {

        let value =
            this.value.replace(/\D/g, '');

        this.value =
            format(value);

        cards.forEach(c => {

            c.classList.remove('active');

            const mark =
                c.querySelector('.checkmark');

            if (mark) {
                mark.remove();
            }

        });

        updateSummary(value);

    });

    updateSummary(10000);

});
</script>