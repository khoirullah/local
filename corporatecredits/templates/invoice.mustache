<div class="invoice-wrapper">

    <div class="invoice-card">

        <h2>Invoice Generated</h2>

        <div class="invoice-row">
            <span>Invoice</span>
            <strong>{{invoicecode}}</strong>
        </div>

        <div class="invoice-row">
            <span>Coins</span>
            <strong>{{coins}}</strong>
        </div>

        <div class="invoice-row">
            <span>Amount</span>
            <strong>Rp {{amount}}</strong>
        </div>

        <div class="invoice-row">
            <span>Status</span>
            <span class="badge badge-warning">
                {{status}}
            </span>
        </div>

        <hr>

        <h4>
            Payment Instructions
        </h4>

        <p>
            Transfer to:
        </p>

        <div class="va-box">
            BCA Virtual Account
            <br>
            <strong>
                88081234567890
            </strong>
        </div>

        <p>
            Coins will be credited
            automatically after payment.
        </p>

        <a
            href="{{producturl}}"
            class="btn btn-primary">

            Browse Products

        </a>

    </div>

</div>