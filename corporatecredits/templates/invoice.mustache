<div class="invoice-wrapper">

    <div class="invoice-card shadow">

        <div class="invoice-header">

            <div class="invoice-icon">
                <i class="fa fa-file-invoice-dollar"></i>
            </div>

            <h2>
                Invoice Created
            </h2>

            <p>
                Complete your payment to receive your coins automatically.
            </p>

        </div>

        <div class="status-box">

            <span class="status-label">
                Payment Status
            </span>

            <span class="badge badge-warning px-3 py-2">
                {{status}}
            </span>

        </div>

        <div class="alert alert-warning mt-3">

            Checking payment status...

            <strong id="countdown">{{invoiceexpiry}}</strong>s

        </div>

        <div class="invoice-details">

            <div class="invoice-row">
                <span>Invoice Number</span>
                <strong>{{invoicecode}}</strong>
            </div>

            <div class="invoice-row">
                <span>Coins</span>
                <strong>🪙 {{coins}}</strong>
            </div>

            <div class="invoice-row total">
                <span>Total Payment</span>
                <strong class="amount">
                    Rp {{amount}}
                </strong>
            </div>

        </div>

        <div class="instruction-card">

            <h4>
                <i class="fa fa-university mr-2"></i>
                Payment Instructions
            </h4>

            <p class="mb-2">
                Please transfer the exact amount to:
            </p>

            <div class="va-box">

                <small>BCA Virtual Account</small>

                <div class="va-number">
                    88081234567890
                </div>

            </div>

            <div class="alert alert-info mt-3 mb-0">

                <i class="fa fa-info-circle"></i>

                Your balance will be updated automatically once the payment has been confirmed.

            </div>

        </div>

        <div class="invoice-actions">

            <a
                href="{{producturl}}"
                class="btn btn-primary btn-lg btn-block">

                <i class="fa fa-shopping-cart mr-2"></i>

                Browse Products

            </a>

        </div>

    </div>

</div>

<script>

document.addEventListener('DOMContentLoaded', function() {

    const invoiceid = {{invoiceid}};
    let remaining = {{invoiceexpiry}};

    const countdown =
        document.getElementById('countdown');

    const timer = setInterval(function() {

        remaining--;

        countdown.textContent = remaining;

        fetch(
            M.cfg.wwwroot +
            '/local/corporatecredits/check_invoice.php?id=' +
            invoiceid
        )
        .then(response => response.json())
        .then(data => {

            if (data.status === 'paid') {

                clearInterval(timer);

                window.location =
                    M.cfg.wwwroot +
                    '/local/corporatecredits/payment_success.php?id=' +
                    invoiceid;

            }

        });

        if (remaining <= 0) {

            clearInterval(timer);

            window.location =
                M.cfg.wwwroot +
                '/local/corporatecredits/payment_failed.php?id=' +
                invoiceid;

        }

    }, 1000);

});

</script>