<div class="row mb-4">

    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">

                <h6>Total Credit In</h6>

                <div class="h2">
                    {{creditin}}
                </div>

            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">

                <h6>Total Credit Out</h6>

                <div class="h2">
                    {{creditout}}
                </div>

            </div>
        </div>
    </div>

</div>

<div class="card shadow-sm border-0">

    <div class="card-header">

        <strong>
            Transaction History
        </strong>

    </div>

    <div class="table-responsive">

        <table class="table table-hover mb-0">

            <thead>

                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>Balance After</th>
                    <th>Description</th>
                </tr>

            </thead>

            <tbody>

            {{#transactions}}

                <tr>

                    <td>{{date}}</td>

                    <td>{{type}}</td>

                    <td>{{amount}}</td>

                    <td>{{balanceafter}}</td>

                    <td>{{description}}</td>

                </tr>

            {{/transactions}}

            {{^transactions}}

                <tr>

                    <td colspan="5"
                        class="text-center text-muted">

                        No transactions found

                    </td>

                </tr>

            {{/transactions}}

            </tbody>

        </table>

    </div>

</div>