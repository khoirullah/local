<!-- Tab panes -->
{{{tabcontent}}}
<style>
    .company-profile{
        border-radius:10px;
    }

    .company-logo img{
        width:80px;
        height:80px;
        object-fit:cover;
    }

    .logo-placeholder{
        width:80px;
        height:80px;
        background:#e9ecef;
        display:flex;
        align-items:center;
        justify-content:center;
        text-align:center;
        font-size:12px;
        border-radius:10px;
        color:#666;
    }

    .company-desc{
        max-width:600px;
        line-height:1.4;
    }

    .stats-cards {
        gap: 10px;
    }

    .stat-card {
        flex: 1;
        min-width: 180px;
    }

    .stat-card .card {
        border-radius: 8px;
    }

    .stat-card small {
        font-size: 12px;
        opacity: .9;
    }
    .stat-card h5{
        font-size: 22px;
        letter-spacing: .5px;
    }
    #completions{
        height:300px;
    }
    .subscription-card {
        border-radius: 14px;
        transition: all .25s ease;
    }
    .subscription-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.12);
    }
</style>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function () {

    const ctx = document.getElementById('enrollments');

    if (!ctx) return;

    const chart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: {{{enrollmentlabels}}},
            datasets: [{
                label: 'Enrollments',
                data: {{{enrollmentdata}}},
                borderWidth: 2,
                fill: false,
                tension: 0.2
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                yAxes: [{
                    ticks: {
                        beginAtZero: true
                    }
                }]
            }
        }
    });

});
</script>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const ctxCompletion = document.getElementById('completions');

        if (!ctxCompletion) return;

        new Chart(ctxCompletion, {
            type: 'bar',
            data: {
                labels: {{{completionlabels}}},
                datasets: [{
                    //label: {{#str}} clientcompletion, local_company {{/str}},
                    label: 'Completion %',
                    data: {{{completiondata}}},
                    borderWidth: 1
                }]
            },
            options: {
                indexAxis: 'y', // 🔥 horizontal bar
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: {
                        min: 0,
                        max: 100,
                        ticks: {
                            callback: function(value) {
                                return value + '%';
                            }
                        }
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });

    });
</script>
