<div class="company-header mb-4">
    <div class="company-header position-relative">
        <h1 class="company-title mb-3">
            {{companyname}}
        </h1>
        <div class="wallet-summary card shadow-sm">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">

                    <div>
                        <div class="wallet-label text-muted">
                            Current Balance
                        </div>

                        <div class="wallet-balance">
                            {{wallet.balance}} 🪙
                        </div>
                    </div>

                    <a href="{{topupurl}}" class="btn btn-success">
                        <img
                            src="{{topupicon}}"
                            alt="Top Up"
                            width="30"
                            height="30"
                            class="mr-1"
                        >
                    </a>

                </div>

            </div>
        </div>
    </div>

    <ul class="nav company-nav mt-3">
        <li class="nav-item">
            <a class="nav-link {{#overviewactive}}active{{/overviewactive}}" href="{{overviewurl}}">
                <i class="fa fa-home mr-1"></i>
                {{#str}} navoverview, local_company {{/str}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#entitlementsactive}}active{{/entitlementsactive}}" href="{{entitlementsurl}}">
                <i class="fa fa-tag mr-1"></i>
                {{#str}} naventitlements, local_company {{/str}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#membersactive}}active{{/membersactive}}" href="{{membersurl}}">
                <i class="fa fa-users mr-1"></i>
                {{#str}} navmembers, local_company {{/str}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#assignmentsactive}}active{{/assignmentsactive}}" href="{{assignmentsurl}}">
                <i class="fa fa-clipboard mr-1"></i>
                {{#str}} navassignments, local_company {{/str}}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#walletactive}}active{{/walletactive}}" href="{{walleturl}}">
                <i class="fa fa-credit-card mr-1"></i>
                {{#str}} navwallet, local_company {{/str}}
            </a>
        </li>
    </ul>

</div>

{{{tabcontent}}}

<style>
   .company-title{
        font-size: 2.2rem;
        font-weight: 700;
    }

    .company-nav{
        border-bottom: none;
    }

    .company-nav .nav-link{
        border: 1px solid #dee2e6;
        border-bottom: none;
        border-radius: 12px 12px 0 0;
        margin-right: 6px;
        color: #495057;
        background: #fff;
        padding: .75rem 1.25rem;
        font-weight: 500;
    }

    .company-nav .nav-link.active{
        background: var(--primary);
        color: #fff;
        border-color: var(--primary);
    }

    .company-header{
        position: relative;
    }

    .stats-cards {
        gap: 10px;
    }

    .stat-card {
        flex: 1;
        min-width: 180px;
    }

    .stat-card .card {
        border-radius: 8px;
    }

    .stat-card small {
        font-size: 12px;
        opacity: .9;
    }
    .stat-card h5{
        font-size: 22px;
        letter-spacing: .5px;
    }
    #completions{
        height:300px;
    }

    /* =====================
    DESKTOP
    ===================== */
    .wallet-summary{
        position: absolute;
        top: 0;
        right: 0;

        width: 240px;

        border: 0;
        border-radius: 16px;
        z-index: 10;
    }


    /* =====================
    TABLET
    ===================== */
    @media (max-width: 991.98px){
        .company-nav{
            display:grid;
            grid-template-columns:repeat(2,1fr);
            gap:.5rem;
            border:none;
        }

        .company-nav .nav-item{
            width:100%;
        }

        .company-nav .nav-link{
            border-radius:12px;
            text-align:center;
            padding:.75rem;
            margin:0;
            border:1px solid #dee2e6;
        }
        .wallet-summary{
            width:100%;
            margin:1rem 0;
            position:static;
        }

        .company-title{
            font-size:2.2rem;
            line-height:1.2;
            margin-bottom:1rem;
        }

        .wallet-balance{
            font-size:2rem;
            font-weight:700;
        }
        .company-content{
            margin-top:1rem;
        }
    }

    /* =====================
    MOBILE
    ===================== */
    @media (max-width: 767.98px){
        .company-nav{
            display:flex;
            flex-direction:column;
            gap:.5rem;
            border:none;
        }

        .company-nav .nav-item{
            width:100%;
        }

        .company-nav .nav-link{
            display:flex;
            align-items:center;

            width:100%;
            padding:.85rem 1rem;

            border:1px solid #dee2e6;
            border-radius:12px;

            margin:0;
            background:#fff;

            font-weight:500;
        }

        .company-nav .nav-link.active{
            background:var(--primary);
            border-color:var(--primary);
            color:#fff;
        }

        .company-nav .nav-link i{
            width:24px;
            text-align:center;
            margin-right:.75rem;
        }
        .wallet-summary{
            width:100%;
            margin:1rem 0;
            position:static;
        }

        .company-title{
            font-size:2.2rem;
            line-height:1.2;
            margin-bottom:1rem;
        }

        .wallet-balance{
            font-size:2rem;
            font-weight:700;
        }
        .company-content{
            margin-top:1rem;
        }
    }
</style>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function () {

    const ctx = document.getElementById('enrollments');

    if (!ctx) return;

    const chart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: {{{enrollmentlabels}}},
            datasets: [{
                label: 'Enrollments',
                data: {{{enrollmentdata}}},
                borderWidth: 2,
                fill: false,
                tension: 0.2
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                yAxes: [{
                    ticks: {
                        beginAtZero: true
                    }
                }]
            }
        }
    });

});
</script>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const ctxCompletion = document.getElementById('completions');

        if (!ctxCompletion) return;

        new Chart(ctxCompletion, {
            type: 'bar',
            data: {
                labels: {{{completionlabels}}},
                datasets: [{
                    //label: {{#str}} clientcompletion, local_company {{/str}},
                    label: 'Completion %',
                    data: {{{completiondata}}},
                    borderWidth: 1
                }]
            },
            options: {
                indexAxis: 'y', // 🔥 horizontal bar
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: {
                        min: 0,
                        max: 100,
                        ticks: {
                            callback: function(value) {
                                return value + '%';
                            }
                        }
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });

    });
</script>
