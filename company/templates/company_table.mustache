<div class="mb-4 d-flex justify-content-between align-items-center">

    <a href="{{addurl}}" class="btn btn-primary">
        {{#str}} addcompany, local_company {{/str}}
    </a>

    <form method="get" class="d-flex">
        <input type="text"
               name="search"
               value="{{search}}" 
               class="form-control me-2"
               placeholder="{{#str}} searchcompany, local_company {{/str}}">
        <select name="status" class="form-control me-2">
            <option value="">{{#str}} filterstatus, local_company {{/str}}</option>
            <option value="Active" {{#statusactive}}selected{{/statusactive}}>{{#str}} statusactive, local_company {{/str}}</option>
            <option value="Expiring" {{#statusexpiring}}selected{{/statusexpiring}}>{{#str}} statusexpiring, local_company {{/str}}</option>
            <option value="Suspended" {{#statussuspend}}selected{{/statussuspend}}>{{#str}} statussuspend, local_company {{/str}}</option>
        </select>
        <select name="util" class="form-control me-2">
            <option value="">{{#str}} filterutilization, local_company {{/str}}</option>
            <option value="Low" {{#utillow}}selected{{/utillow}}>{{#str}} utilizationlow, local_company {{/str}}</option>
            <option value="Medium" {{#utilmedium}}selected{{/utilmedium}}>{{#str}} utilizationmedium, local_company {{/str}}</option>
            <option value="High" {{#utilhigh}}selected{{/utilhigh}}>{{#str}} utilizationhigh, local_company {{/str}}</option>
        </select>
        <button class="btn btn-outline-primary">
            {{#str}} apply, local_company {{/str}}
        </button>
    </form>

</div>

<div class="table-responsive">

    <table class="table table-bordered table-hover">
        <thead class="table-primary text-center">
            <tr>
                <th>{{#str}} clientname, local_company {{/str}}</th>
                <th>{{#str}} clientstatus, local_company {{/str}}</th>
                <th>{{#str}} clientcourse, local_company {{/str}}</th>
                <th>{{#str}} clientquota, local_company {{/str}}</th>
                <th>{{#str}} clientquotaused, local_company {{/str}}</th>
                <th>{{#str}} clientquotaleft, local_company {{/str}}</th>
                <th>{{#str}} clientquotautil, local_company {{/str}}</th>
                <th>{{#str}} clientaction, local_company {{/str}}</th>
            </tr>
        </thead>

        <tbody>

        {{#companies}}
            <tr>
                <td>
                    <a href="{{detailurl}}">{{name}}</a>
                </td>

                <td class="text-center">
                    <span class="text-white p-2 {{statusclass}}">
                        {{clientstatus}}
                    </span>
                </td>

                <td class="text-center">{{activecourses}}</td>
                <td>{{quota}}</td>
                <td>{{used}}</td>
                <td>{{left}}</td>

                <td class="{{rowclass}}">
                    {{utiltext}}
                </td>

                <td class="text-center">
                    <a href="{{editurl}}">{{#str}} edit, local_company {{/str}}</a> |
                    <a href="{{deleteurl}}">{{#str}} delete, local_company {{/str}}</a>
                </td>
            </tr>
        {{/companies}}

        {{^companies}}
            <tr>
                <td colspan="8" class="text-center text-muted">
                    {{#str}} nocompanies, local_company {{/str}}
                </td>
            </tr>
        {{/companies}}

        </tbody>
    </table>

</div>