<div class="d-flex flex-wrap mt-2 text-muted">
    {{#str}} entdesc, local_company {{/str}}
</div>
<div class="d-flex flex-wrap my-3 stats-cards">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>{{#str}} entproduct, local_company {{/str}}</th>
                <th>{{#str}} enttotal, local_company {{/str}}</th>
                <th>{{#str}} entused, local_company {{/str}}</th>
                <th>{{#str}} entavailable, local_company {{/str}}</th>
                <th>{{#str}} entstatus, local_company {{/str}}</th>
            </tr>
        </thead>

        <tbody>

            {{#entitlements}}

            <tr>
                <td>{{productname}}</td>
                <td>{{qty}}</td>
                <td>{{usedqty}}</td>
                <td>{{available}}</td>
                <td>{{status}}</td>
            </tr>

            {{/entitlements}}
            {{^entitlements}}

            <tr>
                <td colspan="5" class="alert-info text-center">{{#str}} nosub, local_company {{/str}}</td>
            </tr>

            {{/entitlements}}

        </tbody>

    </table>
</div>