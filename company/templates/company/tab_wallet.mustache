<div class="row mb-4">

    <!-- BALANCE CARD -->
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <small class="text-muted mb-1">
                        {{#str}}balance, local_company{{/str}}
                    </small>

                    <h3 class="font-weight-bold mb-3">
                        {{wallet.balance}}
                    </h3>
                </div>
                
                <div class="d-flex justify-content-between align-items-center">
                    <div class="flex-fill">
                        <small class="text-muted d-block mb-1">
                            {{#str}}creditin, local_company{{/str}}
                        </small>

                        <p class="mb-0 text-success">
                            + {{wallet.creditin}}
                        </p>
                    </div>

                    <div class="flex-fill text-right">
                        <small class="text-muted d-block mb-1">
                            {{#str}}creditout, local_company{{/str}}
                        </small>

                        <p class="mb-0 text-danger">
                            - {{wallet.creditout}}
                        </p>
                    </div>

                </div>

            </div>
        </div>
    </div>

    <!-- RECENT TRANSACTIONS -->
    <div class="col-md-8 mb-3">
        <div class="card shadow-sm">

            <div class="card-header bg-white">
                <strong>{{#str}}recenttxn, local_company{{/str}}</strong>
            </div>

            <div class="card-body p-0">

                {{#transactions}}
                <div class="list-group list-group-flush">

                    {{#transactions}}
                    <div class="list-group-item">

                        <div class="d-flex justify-content-between align-items-start">

                            <div>
                                <div class="font-weight-bold">
                                    {{description}}
                                </div>

                                <small class="text-muted">
                                    {{type}} • {{source}} • {{timecreated}}
                                </small>
                            </div>

                            <div class="text-right">
                                <div class="{{amountclass}}">
                                    {{amount}}
                                </div>

                                <small class="text-muted">
                                    Balance: {{balanceafter}}
                                </small>
                            </div>

                        </div>

                    </div>
                    {{/transactions}}

                </div>
                {{/transactions}}

                {{^transactions}}
                <div class="p-3 text-muted">
                    {{#str}}notxn, local_company{{/str}}
                </div>
                {{/transactions}}

            </div>

        </div>
    </div>

</div>

<div class="card shadow-sm border-0">

    <div class="card-header">

        <strong>
            {{#str}}txnhistory, local_company{{/str}}
        </strong>

    </div>

    <div class="table-responsive">

        <table class="table table-hover mb-0">

            <thead>

                <tr>
                    <th>{{#str}}date{{/str}}</th>
                    <th>{{#str}}type, local_company{{/str}}</th>
                    <th>{{#str}}amount, local_company{{/str}}</th>
                    <th>{{#str}}balanceafter, local_company{{/str}}</th>
                    <th>{{#str}}description{{/str}}</th>
                </tr>

            </thead>

            <tbody>

            {{#transactions}}

                <tr>

                    <td>{{timecreated}}</td>

                    <td>{{type}}</td>

                    <td>{{amount}}</td>

                    <td>{{balanceafter}}</td>

                    <td>{{description}}</td>

                </tr>

            {{/transactions}}

            {{^transactions}}

                <tr>

                    <td colspan="5" class="text-center text-muted">

                        {{#str}}txnhistory, local_company{{/str}}

                    </td>

                </tr>

            {{/transactions}}

            </tbody>

        </table>

    </div>

</div>