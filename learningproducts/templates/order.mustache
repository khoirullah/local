<div class="container py-4">

    <div class="row">

        <div class="col-lg-8">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <div class="d-flex">

                        {{#product.image}}
                        <img src="{{product.image}}"
                             class="rounded mr-3"
                             width="90"
                             height="90">
                        {{/product.image}}

                        <div class="flex-grow-1">

                            <h2 class="mb-1">
                                {{product.name}}
                            </h2>

                            <span class="badge badge-light">
                                {{product.categoryname}}
                            </span>

                            <span class="badge badge-primary">
                                {{product.type}}
                            </span>

                            <p class="text-muted mb-0">
                                {{#str}}shortdesc, local_learningproducts{{/str}}
                            </p>

                        </div>

                    </div>

                </div>

            </div>

            <div class="card shadow-sm border-0 my-4">

                <div class="card-header bg-white">
                    <strong>{{#str}}about, local_learningproducts{{/str}}</strong>
                </div>

                <div class="card-body">

                    {{{product.description}}}

                </div>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="wallet-summary border-0 card shadow-sm p-2">

                <div class="card-body">

                    <div class="wallet-label text-muted">
                        {{#str}}balance, local_company{{/str}}
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <div class="wallet-balance">
                           <h2> {{wallet.balance}} 🪙</h2>
                        </div>

                        <a href="{{topupurl}}" class="btn btn-success p-2">
                            <img
                                src="{{topupicon}}"
                                alt="Top Up"
                                width="30"
                                height="30">
                        </a>
                    </div>

                </div>

            </div>

            <div class="card shadow-sm border-0 sticky-top my-4">

                <div class="card-header bg-white border-bottom">

                    <h5 class="mb-1">
                        {{#str}}summary, local_learningproducts{{/str}}
                    </h5>

                    <small class="text-muted">
                        {{company.name}}
                    </small>

                </div>

                <div class="card-body">

                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">
                            {{#str}}priceperuser, local_learningproducts{{/str}}
                        </span>
                        <strong id="unit-price">
                            {{product.price}} 🪙
                        </strong>
                    </div>

                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">
                            {{#str}}seat, local_learningproducts{{/str}}
                        </span>
                        <strong id="seat-count">
                            <i class="fa fa-users"></i> 1
                        </strong>
                    </div>

                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">
                            {{#str}}totalprice, local_learningproducts{{/str}}
                        </span>

                        <strong
                            id="total-price"
                            class="text-primary">

                            {{product.price}} 🪙

                        </strong>
                    </div>

                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">
                            {{#str}}billing, local_learningproducts{{/str}}
                        </span>

                        <strong id="billing-period">
                            1 × 30 days
                        </strong>
                    </div>

                    <div class="alert alert-light border mt-3 mb-0">

                        <div class="d-flex justify-content-between">

                            <span class="font-weight-bold">
                                {{#str}}remaining, local_learningproducts{{/str}}
                            </span>

                            <strong
                                id="remaining-balance"
                                class="{{remainingclass}}">

                                {{remainingbalance}} 🪙

                            </strong>

                        </div>

                    </div>

                </div>

                <div class="card-body border-top">

                    {{#notenoughcredit}}

                    <div class="alert alert-danger">

                        {{#str}}insufficient, local_learningproducts{{/str}}

                    </div>

                    {{/notenoughcredit}}

                    {{^notenoughcredit}}

                    <form method="post" action="{{purchaseurl}}">

                        <input type="hidden" name="productid" value="{{product.id}}">
                        <input type="hidden" name="purchase" value="1">
                        <input type="hidden" name="total" id="total-price-field">
                        <input type="hidden" name="sesskey" value="{{sesskey}}">
                        <input type="hidden" id="unit-price-raw" value="{{product.priceraw}}">

                        <div class="form-group">

                            <label for="seat" class="font-weight-bold">

                                {{#str}}seat, local_learningproducts{{/str}}

                            </label>

                            <input
                                type="number"
                                class="form-control"
                                id="seat"
                                name="seat"
                                value="1"
                                min="1"
                                required>

                            <small class="text-muted">

                                {{#str}}numseat, local_learningproducts{{/str}}

                            </small>

                        </div>

                        <div class="form-group">

                            <label class="font-weight-bold">

                                {{#str}}subscriptionperiod, local_learningproducts{{/str}}

                            </label>

                            <div class="row">

                                <div class="col-6">

                                    <input
                                        type="date"
                                        class="form-control"
                                        id="startdate"
                                        name="startdate"
                                        value="{{startdate}}"
                                        required>

                                </div>

                                <div class="col-6">

                                    <input
                                        type="date"
                                        class="form-control"
                                        id="enddate"
                                        name="enddate"
                                        value="{{enddate}}"
                                        required>

                                </div>

                            </div>

                            <small class="text-muted">

                                {{#str}}subscriptionperiod_desc, local_learningproducts{{/str}}

                            </small>

                        </div>

                        <button
                            type="submit"
                            class="btn btn-primary btn-lg btn-block mt-4">

                            <i class="fa fa-shopping-cart mr-2"></i>

                            {{#str}}purchase, local_learningproducts{{/str}}

                        </button>

                    </form>

                    {{/notenoughcredit}}

                </div>

            </div>

        </div>

    </div>

</div>
<script>
document.addEventListener('DOMContentLoaded', function () {

    const seatInput = document.getElementById('seat');

    const unitPrice = parseFloat(
        document.getElementById('unit-price-raw').value
    );

    const walletBalance = {{walletbalance}};

    const seatCount = document.getElementById('seat-count');
    const totalPrice = document.getElementById('total-price');
    const totalfield = document.getElementById('total-price-field');
    const remainingBalance = document.getElementById('remaining-balance');

    function formatNumber(value) {
        return value.toLocaleString('en-US');
    }

    function refreshSummary() {

        let seat = parseInt(seatInput.value, 10);

        if (isNaN(seat) || seat < 1) {
            seat = 1;
            seatInput.value = 1;
        }

        const start = new Date(document.getElementById('startdate').value);
        const end   = new Date(document.getElementById('enddate').value);

        let multiplier = 1;

        if (!isNaN(start) && !isNaN(end) && end >= start) {

            const diffDays = Math.ceil(
                (end - start) / (1000 * 60 * 60 * 24)
            ) + 1;

            multiplier = Math.max(
                1,
                Math.ceil(diffDays / 30)
            );

            const billing = document.getElementById('billing-period');

            if (billing) {
                billing.textContent =
                    multiplier + ' × 30 days';
                    //multiplier + ' × 30 days (' + diffDays + ' days)';
            }
        }

        const total = seat * unitPrice * multiplier;

        const remaining = walletBalance - total;

        seatCount.innerHTML =
            seat+' 👥';

        totalPrice.textContent =
            formatNumber(total) + ' 🪙';

        totalfield.value = formatNumber(total);

        remainingBalance.textContent =
            formatNumber(remaining) + ' 🪙';

        remainingBalance.classList.remove(
            'text-success',
            'text-danger'
        );

        remainingBalance.classList.add(
            remaining >= 0
                ? 'text-success'
                : 'text-danger'
        );
    }

    document.getElementById('startdate')
    .addEventListener('change', refreshSummary);

    document.getElementById('enddate')
        .addEventListener('change', refreshSummary);

    seatInput.addEventListener('input', refreshSummary);

    refreshSummary();


});
</script>