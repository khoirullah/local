<div class="container py-4">

    <div class="row">

        <div class="col-lg-8">

            <div class="card shadow-sm border-0">

                <div class="card-body">

                    <div class="d-flex">

                        {{#product.image}}
                        <img src="{{product.image}}"
                             class="rounded mr-3"
                             width="90"
                             height="90">
                        {{/product.image}}

                        <div class="flex-grow-1">

                            <h2 class="mb-1">
                                {{product.name}}
                            </h2>

                            <span class="badge badge-light">
                                {{product.categoryname}}
                            </span>

                            <span class="badge badge-primary">
                                {{product.type}}
                            </span>

                            <p class="text-muted mb-0">
                                {{#str}}shortdesc, local_learningproducts{{/str}}
                            </p>

                        </div>

                    </div>

                </div>

            </div>

            <div id="accordion">
                <div class="card shadow-sm border-0 my-4">
                    <div class="card-header">
                        <a class="card-link" data-toggle="collapse" href="#collapseOne">
                            <strong>{{#str}}about, local_learningproducts{{/str}}</strong>
                        </a>
                    </div>
                    <div id="collapseOne" class="collapse show" data-parent="#accordion">
                        <div class="card-body">
                        {{{product.description}}}
                        </div>
                    </div>
                </div>
            </div>        

            <div class="form-group">

                <label class="font-weight-bold mb-3">
                    {{#str}}subscriptionperiod, local_learningproducts{{/str}}
                </label>

                <div class="subscription-options">

                    {{#plans}}

                    <label class="subscription-card">

                        <input
                            type="radio"
                            name="planid"
                            value="{{id}}"
                            data-price="{{totalprice}}"
                            data-months="{{months}}"
                            {{#checked}}checked{{/checked}}>

                        <div class="subscription-content">

                            <div class="subscription-title">
                                {{name}}
                            </div>

                            <div class="subscription-duration">
                                {{months}} Months
                            </div>

                            <div class="subscription-price">
                                {{totalprice}} 🪙 / Seat
                            </div>

                        </div>

                    </label>

                    {{/plans}}

                </div>

            </div>   

        </div>

        <div class="col-lg-4">

            <div class="wallet-summary border-0 card shadow-sm p-2">

                <div class="card-body">

                    <div class="wallet-label text-muted">
                        {{#str}}balance, local_company{{/str}}
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <div class="wallet-balance">
                           <h2> {{wallet.balance}} 🪙</h2>
                        </div>

                        <a href="{{topupurl}}" class="btn btn-success p-2">
                            <img
                                src="{{topupicon}}"
                                alt="Top Up"
                                width="30"
                                height="30">
                        </a>
                    </div>

                </div>

            </div>

            <div class="card shadow-sm border-0 sticky-top my-4">

                <div class="card-header bg-white border-bottom">

                    <h5 class="mb-1">
                        {{#str}}summary, local_learningproducts{{/str}}
                    </h5>

                    <small class="text-muted">
                        {{company.name}}
                    </small>

                </div>

                <div class="card-body">

                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">
                            {{#str}}priceperuser, local_learningproducts{{/str}}
                        </span>
                        <strong id="unit-price">
                            {{product.price}} 🪙
                        </strong>
                    </div>

                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">
                            {{#str}}seat, local_learningproducts{{/str}}
                        </span>
                        <strong id="seat-count">
                            <i class="fa fa-users"></i> 1
                        </strong>
                    </div>

                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">
                            {{#str}}totalprice, local_learningproducts{{/str}}
                        </span>

                        <strong
                            id="total-price"
                            class="text-primary">

                            {{product.price}} 🪙

                        </strong>
                    </div>

                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted">
                            {{#str}}billing, local_learningproducts{{/str}}
                        </span>

                        <strong id="billing-period">
                            1 × 30 days
                        </strong>
                    </div>

                    <div class="alert alert-light border mt-3 mb-0">

                        <div class="d-flex justify-content-between">

                            <span class="font-weight-bold">
                                {{#str}}remaining, local_learningproducts{{/str}}
                            </span>

                            <strong
                                id="remaining-balance"
                                class="{{remainingclass}}">

                                {{remainingbalance}} 🪙

                            </strong>

                        </div>

                    </div>

                </div>

                <div class="card-body border-top">

                    {{#notenoughcredit}}

                    <div class="alert alert-danger">

                        {{#str}}insufficient, local_learningproducts{{/str}}

                    </div>

                    {{/notenoughcredit}}

                    {{^notenoughcredit}}

                    <form method="post" action="{{purchaseurl}}">

                        <input type="hidden" name="productid" value="{{product.id}}">
                        <input type="hidden" name="purchase" value="1">
                        <input type="hidden" name="total" id="total-price-field">
                        <input type="hidden" name="sesskey" value="{{sesskey}}">
                        <input type="hidden" id="unit-price-raw" value="{{product.priceraw}}">
                        <input type="hidden" id="duration" name="duration">

                        <div class="form-group">

                            <label class="font-weight-bold">
                                {{#str}}seat, local_learningproducts{{/str}}
                            </label>

                            <div class="seat-selector">

                                <button
                                    type="button"
                                    class="btn btn-outline-secondary"
                                    id="seat-minus">

                                    -

                                </button>

                                <input
                                    id="seat"
                                    name="seat"
                                    type="number"
                                    value="1"
                                    min="1"
                                    class="form-control text-center w-100">

                                <button
                                    type="button"
                                    class="btn btn-outline-secondary"
                                    id="seat-plus">

                                    +

                                </button>

                            </div>

                        </div>

                        <button
                            type="submit"
                            class="btn btn-primary btn-lg btn-block mt-4">

                            <i class="fa fa-shopping-cart mr-2"></i>

                            {{#str}}purchase, local_learningproducts{{/str}}

                        </button>

                    </form>

                    {{/notenoughcredit}}

                </div>

            </div>

        </div>

    </div>

</div>
<script>
document.addEventListener('DOMContentLoaded', function () {

    const seatInput = document.getElementById('seat');

    const walletBalance = {{walletbalance}};
    const duration = document.getElementById('duration');
    const seatCount = document.getElementById('seat-count');
    const totalPrice = document.getElementById('total-price');
    const totalField = document.getElementById('total-price-field');
    const remainingBalance = document.getElementById('remaining-balance');
    const billingPeriod = document.getElementById('billing-period');

    function formatNumber(value) {
        return Number(value).toLocaleString('en-US');
    }

    function getSelectedPlan() {
        return document.querySelector(
            'input[name="planid"]:checked'
        );
    }

    function refreshSummary() {

        let seat = parseInt(seatInput.value);

        if (isNaN(seat) || seat < 1) {
            seat = 1;
            seatInput.value = 1;
        }

        const plan = getSelectedPlan();

        if (!plan) {
            return;
        }

        const unitPrice = parseFloat(plan.dataset.price);
        const months = plan.dataset.months;
        const purchaseButton = document.getElementById('purchase-button');

        duration.value = months;

        const total = seat * unitPrice;
        const remaining = walletBalance - total;

        seatCount.innerHTML =
            '<i class="fa fa-users"></i> ' + seat;

        totalPrice.innerHTML =
            formatNumber(total) + ' 🪙';

        totalField.value = total;

        remainingBalance.innerHTML =
            formatNumber(remaining) + ' 🪙';

        remainingBalance.className =
            remaining >= 0
            ? 'text-success'
            : 'text-danger';

        billingPeriod.textContent =
            months + ' Month' + (months > 1 ? 's' : '');

        document.getElementById('unit-price').innerHTML =
            formatNumber(unitPrice) + ' 🪙';

        const enoughCredit = remaining >= 0;

        purchaseButton.disabled = !enoughCredit;

        purchaseButton.classList.toggle('btn-primary', enoughCredit);
        purchaseButton.classList.toggle('btn-secondary', !enoughCredit);

    }

    seatInput.addEventListener('input', refreshSummary);

    document.querySelectorAll('input[name="planid"]')
        .forEach(function(item){

            item.addEventListener(
                'change',
                refreshSummary
            );

        });

    document.getElementById('seat-plus')
        .addEventListener('click', function(){

            seatInput.value =
                parseInt(seatInput.value || 1) + 1;

            refreshSummary();

        });

    document.getElementById('seat-minus')
        .addEventListener('click', function(){

            let value =
                parseInt(seatInput.value || 1);

            if (value > 1) {
                seatInput.value = value - 1;
            }

            refreshSummary();

        });

    refreshSummary();

});
</script>