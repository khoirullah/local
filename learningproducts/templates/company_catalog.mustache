<div class="row">

{{#products}}

<div class="col-md-4">

    <div class="card mb-3">

        <div class="card-body">

            <h5>{{name}}</h5>

            <p>{{price}} credits</p>

            <a
                href="{{url}}"
                class="btn btn-primary"
            >
                Buy
            </a>

        </div>

    </div>

</div>

{{/products}}

</div>