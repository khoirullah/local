<div class="product-detail bg-dark text-white">
{{#products}}
    <h1 class="px-5">{{name}}</h1>
    <ol class="breadcrumb px-5">
        <li class="breadcrumb-item text-danger">
            <a class="text-danger text-decoration-none" href="{{homeurl}}">
                {{#str}}myhome{{/str}}
            </a>
        </li>

        <li class="breadcrumb-item text-danger">
            <a class="text-danger text-decoration-none" href="{{producturl}}">
                {{#str}}pluginname, local_learningproducts{{/str}}
            </a>
        </li>

        <li class="breadcrumb-item text-secondary">
            <span>
                {{name}}
            </span>
        </li>
    </ol>
</div>
<div class="product-detail">

    <div class="container-fluid">

        <div class="row">

            <!-- CONTENT -->
            <div class="col-lg-9">

                <div class="product-content">

                    <section class="content-section">

                        <h1 class="pb-3 mb-5 "
                            style="border-bottom: 5px double #000;">
                            {{#str}}overview, local_learningproducts{{/str}}
                        </h1>
                        
                        {{{description}}}

                    </section>

                    <section class="content-section">
                        <h1>
                            {{#str}}getlearn, local_learningproducts{{/str}}
                        </h1>

                        <div class="row">

                            {{#issingle}}

                                {{#items}}
                                <div class="col-lg-4 mb-4">
                                    <div class="feature-card bg-dark text-white">
                                        <i class="fa fa-graduation-cap text-white"></i>
                                        <h5>
                                            {{fullname}}
                                        </h5>
                                    </div>
                                </div>
                                {{/items}}                          

                                {{#items}}
                                <div class="col-lg-8">
                                    {{{summary}}}
                                </div>
                                {{/items}}

                            {{/issingle}}

                            {{^issingle}}
                            
                                {{#items}}
                                <div class="{{colclass}} mb-4">

                                    <a href="{{producturl}}" class="text-decoration-none">

                                        <div
                                            class="feature-card feature-card-product"
                                            style="background-image:url('{{imageurl}}');"
                                        >

                                            <div class="feature-card-overlay">

                                                <i class="fa fa-archive mb-3"></i>

                                                <h5 class="mb-0">
                                                    {{name}}
                                                </h5>

                                            </div>

                                        </div>

                                    </a>

                                </div>
                                {{/items}}

                            {{/issingle}}

                            {{#morecount}}
                            <div class="{{colclass}}">
                                <div class="feature-card text-center">
                                    <i class="fa fa-plus-circle text-muted"></i>
                                    <h5>
                                        {{morecount}}
                                        {{#str}}moreproducts, local_learningproducts{{/str}}
                                    </h5>
                                </div>
                            </div>
                            {{/morecount}}

                        </div>

                    </section>

                    <section class="content-section">

                        <h1>Frequently Asked Questions</h1>

                        <div class="accordion" id="faqAccordion">

                            <div class="card">
                                <div class="card-header">
                                    How long is this course?
                                </div>
                            </div>

                            <div class="card">
                                <div class="card-header">
                                    Will I receive a certificate?
                                </div>
                            </div>

                            <div class="card">
                                <div class="card-header">
                                    Is this self-paced?
                                </div>
                            </div>

                        </div>

                    </section>

                </div>

            </div>

            <!-- SIDEBAR -->
            <div class="col-lg-3">

                <div class="product-sidebar">

                    <div class="price-card mb-5">
                        <div class="mb-3">
                            <img src="{{imageurl}}" class="product-banner" alt=""> 
                        </div>

                        <small>{{#str}}productprice, local_learningproducts{{/str}}</small>

                        <h2>{{price}} 🪙</h2>

                        {{#isenrolled}}
                        <a href="{{actionurl}}" class="btn btn-success btn-block">
                            {{#str}}contleaning, local_learningproducts{{/str}}
                        </a>
                        {{/isenrolled}}

                        {{^isenrolled}}
                        <a href="{{actionurl}}" class="btn btn-primary btn-block">
                            {{#str}}buy, local_learningproducts{{/str}}
                        </a>
                        {{/isenrolled}}
                        
                    </div>

                    <div class="product-meta-card">

                        <div class="meta-item">
                            <i class="fa fa-folder"></i>
                            <span>{{#str}}category, local_learningproducts{{/str}}</span>
                            <strong>{{categoryname}}</strong>
                        </div>
                        
                        {{^issingle}}
                        <div class="meta-item"> 
                            <i class="fa fa-book"></i>
                            <span>{{#str}}product, local_learningproducts{{/str}}</span>
                            <strong>{{itemcount}}</strong>
                        </div>
                        {{/issingle}}

                        <div class="meta-item">
                            <i class="fa fa-users"></i>
                            <span>{{#str}}participant, local_learningproducts{{/str}}</span>
                            <strong>{{studentcount}}</strong>
                        </div>

                        <div class="meta-item">
                            <i class="fa fa-star"></i>
                            <span>{{#str}}rating, local_learningproducts{{/str}}</span>
                            <strong>{{rating}} ({{ratingcount}})</strong>
                        </div>

                        <div class="meta-item">
                            <i class="fa fa-th-large"></i>
                            <span>{{#str}}type, local_learningproducts{{/str}}</span>
                            <strong>{{tipe}}</strong>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>
{{/products}}

</div>